SECRET_KEY=1234567890abcdef
DATABASE_URL=sqlite:///bioscan.db

# Cambia solo esta línea para alternar entre cloud y local
OLLAMA_CHAT_MODEL=gpt-oss:20b-cloud

# auto = si el modelo parece cloud, usa cloud; si no, local
OLLAMA_PROVIDER=auto

# Ollama local
OLLAMA_LOCAL_BASE_URL=http://host.docker.internal:11434

# Ollama Cloud
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_API_KEY=a97ae5d6751e4e888905d826a46b6073.c0QVPt0gj-TCIex5oOQoN7Pu

# Ajustes
OLLAMA_TEMPERATURE=0.2
OLLAMA_KEEP_ALIVE=30m
OLLAMA_CONNECT_TIMEOUT=10
OLLAMA_READ_TIMEOUT=

# Para gpt-oss usa low / medium / high
# Para otros modelos puede ser true / false
OLLAMA_THINK=low

# Fallback automático a local
OLLAMA_ENABLE_FALLBACK=true
OLLAMA_FALLBACK_MODEL=qwen3.5:9b
OLLAMA_FALLBACK_PROVIDER=local
OLLAMA_FALLBACK_THINK=false


ADMIN_USER=admin
ADMIN_PASS=admin123456
CREATE_ADMIN_ON_BOOT=true
SEED_ON_BOOT=false



OLLAMA_EMBED_MODEL=nomic-embed-text

GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

