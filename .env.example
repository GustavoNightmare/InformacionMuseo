# =========================
# Flask / App
# =========================
SECRET_KEY=cambia-esta-clave-secreta
DATABASE_URL=sqlite:///bioscan.db
MUSEO_TTS_SHARED_KEY=pon_aqui_una_clave_compartida_tts
MUSEO_TTS_INTERNAL_BASE_URL=http://servertts:8010
# =========================
# Server TTS (FastAPI)
# =========================
TTS_API_KEY=pon_aqui_una_clave_para_dispositivos_tts
# URL publica del server TTS (normalmente la URL HTTPS de ngrok-tts)
MUSEO_TTS_PUBLIC_BASE_URL=
EDGE_TTS_VOICE=es-CO-GonzaloNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%

# =========================
# Admin inicial
# =========================
ADMIN_USER=admin
ADMIN_PASS=admin123456
CREATE_ADMIN_ON_BOOT=true
SEED_ON_BOOT=false

# =========================
# LLM principal
# =========================
OLLAMA_CHAT_MODEL=gpt-oss:20b-cloud
OLLAMA_PROVIDER=auto

# =========================
# Ollama Cloud
# =========================
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_API_KEY=pon_aqui_tu_api_key_de_ollama_cloud

# =========================
# Ollama local dentro de Docker
# =========================
OLLAMA_LOCAL_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_URL=http://ollama:11434/api/chat
OLLAMA_EMBED_URL=http://ollama:11434/api/embed

# =========================
# Modelo embedding para RAG
# =========================
OLLAMA_EMBED_MODEL=nomic-embed-text

# =========================
# Ajustes de generación
# =========================
OLLAMA_TEMPERATURE=0.2
OLLAMA_KEEP_ALIVE=30m
OLLAMA_CONNECT_TIMEOUT=10
OLLAMA_READ_TIMEOUT=
OLLAMA_THINK=low

# =========================
# Fallback automático a local
# =========================
OLLAMA_ENABLE_FALLBACK=true
OLLAMA_FALLBACK_MODEL=qwen3.5:9b
OLLAMA_FALLBACK_PROVIDER=local
OLLAMA_FALLBACK_THINK=false

# =========================
# Gunicorn
# =========================
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# =========================
# Ngrok app principal (Flask)
# =========================
NGROK_AUTHTOKEN=pon_aqui_tu_token_de_ngrok

# =========================
# Ngrok dedicado para Server TTS
# =========================
NGROK_TTS_AUTHTOKEN=pon_aqui_tu_token_de_ngrok_para_tts
